# GigShield v5.0 — Environment Variables
# Copy this to .env and fill your values

# ── Server ───────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=gigshield-change-this-in-production
ADMIN_SECRET=admin2026

# ── Weather API (OpenWeatherMap) ──────────────────────────────
# Free key: https://openweathermap.org/api
# Leave empty → uses realistic mock data (demo works without it)
OWM_API_KEY=

# ── SMS OTP (Fast2SMS) ────────────────────────────────────────
# Free key: https://fast2sms.com
# Leave empty → OTP prints in terminal (demo works without it)
FAST2SMS_KEY=

# ── Razorpay Payments ─────────────────────────────────────────
# Leave empty → payouts are simulated (demo works without it)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
